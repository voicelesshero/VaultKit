# Copy this file to .env and fill in real values before running locally.
# In production (Railway/Render), set these as platform environment variables.

# Generate a strong secret with:
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-strong-random-secret-here

# Set to "production" when deploying. Triggers secret key validation and disables debug mode.
FLASK_ENV=development
